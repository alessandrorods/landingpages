# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mundoplanta.com.br

# ─── Token de confirmação (HMAC-SHA256) ───────────────────────────────────────
# Gere com: openssl rand -hex 32
PAYLOAD_ENCODER_SECRET=

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Painel → Seu negócio → Credenciais
# Use o token TEST-... em dev e APP_USR-... em produção
MP_ACCESS_TOKEN=
# Painel → Suas integrações → Notificações → Secret
MP_WEBHOOK_SECRET=

# ─── Olist / Tiny ERP ─────────────────────────────────────────────────────────
# Painel Tiny → Configurações → API → Token
TINY_TOKEN=

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── Google Ads ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION=XXXXXXXXXXX

# ─── Google Tag Manager ───────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── Meta Pixel ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXX

# Segredo para assinar os cookies de sessão (qualquer string longa e aleatória)
# Gerar com openssl rand -hex 32
ADMIN_SECRET=gere-algo-aqui-ex-openssl-rand-hex-32

# Senhas por área
VENDAS_PASSWORD=senha-da-equipe-de-vendas
FLORISTA_PASSWORD=senha-da-florista
EXPEDICAO_PASSWORD=senha-da-expedicao
MOTOBOY_PASSWORD=senha-do-motoboy
ADMIN_PASSWORD=senha-do-admin