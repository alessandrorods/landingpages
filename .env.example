# ─── Tiny ERP / Olist ─────────────────────────────────────────────────────────
# Token da API Tiny (Olist ERP) — gerado em: Configurações > API > Token de Acesso
# Docs: https://tiny.com.br/api-docs/api2-pedidos-incluir
TINY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# Measurement ID — começa com G-
# Onde achar: GA4 > Admin > Data Streams > seu stream > Measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── Google Ads ───────────────────────────────────────────────────────────────
# Account ID — começa com AW-
# Onde achar: Google Ads > Ferramentas > Tag do Google
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXX

# Conversion Action ID — formato "AW-XXXXXXXXX/YYYYYYY"
# Onde achar: Google Ads > Metas > Conversões > sua conversão > Tag > gtag snippet
# Crie uma conversão do tipo "Compra" apontando para a página /dia-das-maes/confirmacao
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION=AW-XXXXXXXXX/YYYYYYY

# ─── Meta Pixel ───────────────────────────────────────────────────────────────
# Pixel ID — número de 15-16 dígitos
# Onde achar: Meta Business Suite > Events Manager > seu pixel > Settings
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXX

# ─── Site ─────────────────────────────────────────────────────────────────────
# URL base sem barra final — usado em metadata, OG, canonical, sitemap, JSON-LD
NEXT_PUBLIC_SITE_URL=https://l.floramundoplanta.com.br

# --- Senhas do admin
# senhas que os usuarios da operação usam pra logar
VENDAS_PASSWORD=XXXXXXXX
FLORISTA_PASSWORD=XXXXXXXX
EXPEDICAO_PASSWORD=XXXXXXXX
MOTOBOY_PASSWORD=XXXXXXXX
ADMIN_PASSWORD=XXXXXXXX

# ---- Secret para encoding de cookie no admin
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX