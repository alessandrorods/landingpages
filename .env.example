# ─── Site ─────────────────────────────────────────────────────────────────────
# URL base sem barra final — usado em metadata, OG, canonical, sitemap, JSON-LD
NEXT_PUBLIC_SITE_URL=https://mundoplanta.com.br

# ─── PostgreSQL (Prisma) ──────────────────────────────────────────────────────
# Valores padrão do docker-compose.yml local
# Produção: altere usuário, senha e host conforme o ambiente
DATABASE_URL="postgresql://user:password@localhost:5432/mundoplanta?schema=public"

# ─── Criptografia ─────────────────────────────────────────────────────────────
# Chave mestra para todas as operações HMAC-SHA256 da aplicação
# (sessões, senhas, tokens de pagamento)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_KEY=

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Painel → Seu negócio → Credenciais
# Dev: token começa com TEST-... | Prod: começa com APP_USR-...
MP_ACCESS_TOKEN=
# Painel → Suas integrações → Notificações → chave secreta do webhook
MP_WEBHOOK_SECRET=

# ─── Olist / Tiny ERP ─────────────────────────────────────────────────────────
# Painel Tiny → Configurações → API → Token de Acesso
TINY_TOKEN=

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
# Segredo para autenticar chamadas do cron job em POST /api/admin/orders/sync
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# GA4 → Admin → Fluxos de dados → seu fluxo → ID de medição
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── Google Ads ───────────────────────────────────────────────────────────────
# Google Ads → Ferramentas → Tag do Google → ID da conta
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-XXXXXXXXXX
# Google Ads → Metas → Conversões → sua conversão → Tag → snippet gtag
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION=AW-XXXXXXXXXX/XXXXXXXXXXX

# ─── Google Tag Manager ───────────────────────────────────────────────────────
# tagmanager.google.com → seu container → ID do contêiner
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── Meta Pixel ───────────────────────────────────────────────────────────────
# Meta Business Suite → Gerenciador de Eventos → seu pixel → Configurações
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXX
